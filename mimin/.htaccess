# 1. SECURITY & PRIVACY
Options -Indexes
Header set X-Frame-Options "SAMEORIGIN"

<Files ".htaccess">
    Require all denied
</Files>

<FilesMatch "(\.(bak|config|sql|ini|log|sh|inc|swp|dist)|~)$">
    Require all denied
</FilesMatch>

# 2. ENABLE REWRITE
RewriteEngine On

# 3. FORCE HTTPS
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !localhost
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 4. HOTLINK PROTECTION
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?oldschool\.my\.id [NC]
RewriteCond %{HTTP_HOST} !localhost
RewriteCond %{HTTP_REFERER} !google [NC]
RewriteCond %{HTTP_REFERER} !bing [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg)$ - [F]

# 5. ROUTING (Clean URLs)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/?$ index.php?page=$1 [L,QSA]

# 6. CUSTOM ERROR PAGES
ErrorDocument 404 /views/errors/404.html
ErrorDocument 403 /views/errors/403.html
