# 1. SECURITY & PRIVACY
Options -Indexes
Header set X-Frame-Options "SAMEORIGIN"

<Files ".htaccess">
    Require all denied
</Files>

<FilesMatch "(\.(bak|config|sql|ini|log|sh|inc|swp|dist)|~)$">
    Require all denied
</FilesMatch>

# 2. REDIRECTS & URL CLEANUP
RewriteEngine On

# Force HTTPS (SKIP on localhost)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. HOTLINK PROTECTION (SKIP on localhost)
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?oljen\.my\.id [NC]
RewriteCond %{HTTP_REFERER} !google [NC]
RewriteCond %{HTTP_REFERER} !bing [NC]
RewriteRule \.(jpg|jpeg|png|gif|svg)$ - [F]

# 4. CUSTOM ERROR PAGES
ErrorDocument 404 /views/errors/404.html
ErrorDocument 403 /views/errors/403.html
